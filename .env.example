# Configuracao exclusivamente didatica para o ambiente local academico.
# Copie este arquivo para .env antes de iniciar o Docker Compose.
# Nao use estas credenciais em producao e nao versione o arquivo .env.
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
_PIP_ADDITIONAL_REQUIREMENTS=-r /opt/airflow/requirements.txt
